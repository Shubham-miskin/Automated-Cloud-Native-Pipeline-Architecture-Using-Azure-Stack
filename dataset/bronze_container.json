{
	"name": "bronze_container",
	"properties": {
		"linkedServiceName": {
			"referenceName": "mylakeplace31",
			"type": "LinkedServiceReference"
		},
		"parameters": {
			"year": {
				"type": "string"
			},
			"month": {
				"type": "string"
			}
		},
		"annotations": [],
		"type": "Parquet",
		"typeProperties": {
			"location": {
				"type": "AzureBlobFSLocation",
				"fileName": {
					"value": "@concat(\n    'green_tripdata_',\n    dataset().year,\n    '-',\n    dataset().month,\n    '.parquet')",
					"type": "Expression"
				},
				"folderPath": {
					"value": "@concat(dataset().year,\n'/',\ndataset().month)",
					"type": "Expression"
				},
				"fileSystem": {
					"value": "@concat('bronze','/','trip-data')",
					"type": "Expression"
				}
			},
			"compressionCodec": "snappy"
		},
		"schema": []
	},
	"type": "Microsoft.DataFactory/factories/datasets"
}